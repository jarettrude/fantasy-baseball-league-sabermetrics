# Moose Sports Empire - Environment Variables
# Copy this file to .env for local development
# Production uses docker secrets instead of .env files

# Application Environment
APP_ENV=development
LOG_LEVEL=INFO
DEMO_MODE=false

# URLs and Origins
WEB_ORIGIN=https://localhost
PUBLIC_API_URL=https://localhost
YAHOO_REDIRECT_URI=https://localhost/callback

# Timezone and Scheduling
LOCAL_TIMEZONE=America/Vancouver
RECAP_GENERATION_TIME=10:00

# Database and Redis (local dev only - production uses docker secrets)
DATABASE_URL=postgresql+asyncpg://moose:moose@db:5432/moose_empire
REDIS_URL=redis://redis:6379/0

# NOTE: All sensitive credentials (API keys, secrets, passwords) are stored in ./secrets/ directory
# See ./secrets/README.md for instructions on setting up local secrets
