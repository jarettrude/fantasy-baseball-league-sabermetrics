---
import BaseLayout from "../layouts/BaseLayout.astro";

const reason = Astro.url.searchParams.get("reason") || "generic";

let title = "Access Denied";
let description =
  "Your credentials have been rejected by the Sabermetric Platform.";
let suggestion =
  "Ensure you are using the correct Yahoo account associated with this league.";
let code = "403";

if (reason === "initialization") {
  title = "Initialization Pending";
  code = "503";
  description =
    "The Moose Sports Empire is currently awaiting commissioner activation.";
  suggestion =
    "The Commissioner must log in first to establish the league connection.";
} else if (reason === "unauthorized") {
  title = "Unauthorized Access";
  code = "403";
  description =
    "Your identity is not recognized as a manager in this specific domain.";
  suggestion =
    "If you belong to this league, please verify your credentials with the administrator.";
} else if (reason === "expired") {
  title = "Session Terminated";
  code = "400";
  description = "The security token provided has expired or is invalid.";
  suggestion =
    "Please attempt to re-initialize your session from the secure portal.";
}
---

<BaseLayout title={title} noindex={true}>
  <div
    class="relative flex min-h-screen items-center justify-center px-page py-16"
  >
    <!-- Standard Grid Background -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none grid-bg">
    </div>

    <div class="relative w-full max-w-md animate-fade-in">
      <div class="card p-8 text-center space-y-6">
        <div class="flex flex-col items-center gap-3">
          <div
            class="flex h-14 w-14 items-center justify-center rounded-full bg-(--color-warning-muted) border border-(--color-warning)"
          >
            <svg
              class="h-7 w-7 text-(--color-warning)"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="3"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
              ></path>
            </svg>
          </div>
          <span
            class="font-mono text-xs font-bold tracking-widest uppercase text-(--color-text-muted)"
          >
            MSE // GATE
          </span>
        </div>

        <h1
          class="font-display text-2xl font-extrabold tracking-tight text-(--color-text)"
        >
          {title}
        </h1>

        <div class="space-y-3">
          <p
            class="font-mono text-xs text-(--color-text-muted) leading-relaxed"
          >
            // {description}
          </p>
          <div class="h-px bg-(--color-border)"></div>
          <p class="text-sm text-(--color-text-secondary) leading-relaxed">
            {suggestion}
          </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/login" class="btn btn-primary"> RE-INITIALIZE // </a>
          <a href="/" class="btn btn-secondary"> EXIT TO HUB </a>
        </div>

        <div class="pt-4 border-t border-(--color-border-subtle)">
          <p
            class="font-mono text-[0.6rem] tracking-wide text-(--color-text-muted)"
          >
            SYSTEM IDENTIFIER: {code}_DENIED_ACCESS_PROTOCOL
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
