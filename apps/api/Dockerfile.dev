# --- Development Stage ---
FROM python:3.12-slim AS dev

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    postgresql-client \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast dependency management
RUN pip install --no-cache-dir uv

# Copy requirements file
COPY apps/api/pyproject.toml ./
COPY apps/api/uv.lock* ./
# Install ALL dependencies (including dev)
RUN uv sync --all-groups

# Copy source and other necessary files
COPY apps/api/ ./
COPY apps/api/src/ ./src/
COPY prompts/ /prompts/

RUN chmod +x /app/entrypoint.sh

# Environment variables
ENV PYTHONPATH=/app/src
ENV PYTHONUNBUFFERED=1

# --- API Development Stage ---
FROM dev AS api-dev
EXPOSE 8000
ENTRYPOINT ["/app/entrypoint.sh"]
# Use uvicorn with --reload from venv
CMD ["/app/.venv/bin/uvicorn", "moose_api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]

# --- Worker Development Stage ---
FROM dev AS worker-dev
# Use arq from venv
CMD ["/app/.venv/bin/arq", "moose_api.worker.WorkerSettings"]
